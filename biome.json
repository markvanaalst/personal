{
	"$schema": "https://biomejs.dev/schemas/2.3.14/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["**", "!components/ui"]
	},
	"formatter": {
		"enabled": false
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"assist": {
		"enabled": false
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"noRedundantAlt": "off",
				"useKeyWithClickEvents": "off",
				"useSemanticElements": "off",
				"noSvgWithoutTitle": "off"
			},
			"performance": {
				"noImgElement": "off"
			},
			"suspicious": {
				"noArrayIndexKey": "off",
				"noDoubleEquals": "off"
			},
			"style": {
				"useImportType": "off"
			}
		}
	}
}
